classDiagram
    class Owner {
        +str name
        +int available_minutes
        +time preferred_start
        +List~Pet~ pets
        +add_pet(pet) None
        +list_tasks() List~Task~
    }

    class Pet {
        +str name
        +str species
        +List~Task~ tasks
        +add_task(task) None
        +remove_task(task) None
    }

    class Task {
        +str id
        +str title
        +int duration_minutes
        +Priority priority
        +Recurrence recurrence
        +time preferred_time
        +bool completed
        +Pet pet
        +mark_complete() None
        +next_occurrence() Task
    }

    class Priority {
        <<enumeration>>
        LOW
        MEDIUM
        HIGH
    }

    class Recurrence {
        <<enumeration>>
        NONE
        DAILY
        WEEKLY
    }

    class Scheduler {
        +sort_tasks(tasks) List~Task~
        +sort_by_time(tasks) List~Task~
        +filter_tasks(owner, completed, pet_name) List~Task~
        +find_conflicts(tasks) List~List~Task~~
        +fits(task, remaining_minutes) bool
        +build_plan(owner, day) DailyPlan
    }

    class DailyPlan {
        +date day
        +List~ScheduledItem~ items
        +List~Task~ skipped
        +int total_minutes
        +add_item(item) None
        +explain() str
    }

    class ScheduledItem {
        +Task task
        +time start_time
        +time end_time
    }

    Owner "1" --> "*" Pet : owns
    Pet "1" o--> "*" Task : has
    Task --> "1" Pet : belongs to
    Task --> Priority : uses
    Task --> Recurrence : repeats
    Scheduler ..> Owner : reads tasks and constraints
    Scheduler ..> DailyPlan : builds
    Scheduler ..> ScheduledItem : creates
    DailyPlan "1" --> "*" ScheduledItem : contains
    ScheduledItem --> Task : wraps
